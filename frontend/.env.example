# CryptoQuant Engine - Frontend Environment Variables
# Copy this file to .env.local and update values for your environment.

# Backend API URL (used by Next.js rewrites for proxying /api/* requests)
API_URL=http://localhost:8000

# WebSocket URL (direct connection to backend, NOT proxied by Next.js)
# Local dev: ws://localhost:8000/ws (backend port, NOT Next.js port)
# Production: wss://yourdomain.com/ws (auto-detected if not set)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
