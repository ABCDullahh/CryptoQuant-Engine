# =============================================================================
# CryptoQuant Engine — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cryptoquant:cryptoquant_dev@localhost:5433/cryptoquant
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Trading Safety ---
TRADING_ENABLED=false
ENVIRONMENT=demo

# --- Exchange ---
BINANCE_API_KEY=your-binance-api-key-here
BINANCE_SECRET=your-binance-secret-here
BINANCE_TESTNET=true

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=CHANGE-ME-TO-RANDOM-STRING-MIN-32-CHARS
CORS_ORIGINS=http://localhost:3000

# --- Risk Defaults ---
DEFAULT_RISK_PCT=0.02
MAX_POSITIONS=5
MAX_PORTFOLIO_HEAT=0.06
MAX_LEVERAGE=10
DEFAULT_LEVERAGE=3

# --- Notifications (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK_URL=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- ML ---
ML_MODELS_DIR=./ml_models
